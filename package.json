{
  "name": "game-wiki",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev": "concurrently -n api,admin -c blue,green \"pnpm dev:api\" \"pnpm dev:admin\"",
    "build": "pnpm -r --filter=!database build",
    "lint": "pnpm -r lint",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "pnpm --filter database exec prisma migrate dev",
    "db:generate": "pnpm --filter database exec prisma generate",
    "db:studio": "pnpm --filter database exec prisma studio",
    "setup": "pnpm install && pnpm db:up && pnpm db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "database": "workspace:*"
  }
}
